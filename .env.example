# OpenRouter API key (required)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Serper.dev API key (required for news search)
# Get one at https://serper.dev
SERPER_API_KEY=...

# AI model selection via OpenRouter (optional - defaults shown)
# See available models at https://openrouter.ai/models
AI_MODEL_FAST=google/gemini-flash-1.5
AI_MODEL_QUALITY=google/gemini-flash-1.5
